# Copy to .env and adjust as needed. All values have safe local-dev defaults.

# ---- Database (swap this to point at any Postgres-compatible instance) ----
DATABASE_URL=postgres://pantry:pantry@localhost:5432/pantrytoplate?sslmode=disable

# ---- Single-binary server (cmd/server — replaces the 5-service setup) ----
SERVER_ADDR=:8080

# ---- Service listen addresses (only needed when running individual microservices) ----
GATEWAY_ADDR=:8080
PANTRY_ADDR=:8081
RECIPE_ADDR=:8082
NUTRITION_ADDR=:8083
GAMIFICATION_ADDR=:8084

# ---- Gateway upstreams (host networking when running services via `make`) ----
PANTRY_URL=http://localhost:8081
RECIPE_URL=http://localhost:8082
NUTRITION_URL=http://localhost:8083
GAMIFICATION_URL=http://localhost:8084

# ---- Recipe provider (swappable) ----
# Options: "themealdb" (free, no key) or "spoonacular" (better results, free key needed)
RECIPE_PROVIDER=themealdb
MEALDB_BASE_URL=https://www.themealdb.com/api/json/v1/1

# Spoonacular — sign up free at https://spoonacular.com/food-api/console
# Set RECIPE_PROVIDER=spoonacular and fill in the key below.
SPOONACULAR_API_KEY=

# ---- Groq API key for Whisper transcription ----
GROQ_API_KEY=

# ---- CORS (comma-separated origins, or * for all) ----
CORS_ALLOWED_ORIGINS=*

# ---- Frontend: where the browser/app reaches the gateway ----
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080
EXPO_PUBLIC_API_BASE_URL=http://localhost:8080
