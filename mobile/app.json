{
  "expo": {
    "name": "PantryToPlate",
    "slug": "pantrytoplate",
    "scheme": "pantrytoplate",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.pantrytoplate.app"
    },
    "android": {
      "package": "com.pantrytoplate.app",
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "pantrytoplate"
            }
          ],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ]
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-asset",
      "expo-font",
      "expo-secure-store",
      [
        "expo-audio",
        {
          "microphonePermission": "Allow PantryToPlate to use your microphone for voice grocery input."
        }
      ],
      "expo-web-browser",
      "expo-file-system"
    ],
    "extra": {
      "apiBaseUrl": "https://backend-pantry-pilot.fly.dev"
    }
  }
}
